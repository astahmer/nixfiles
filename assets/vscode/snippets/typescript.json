{
  // Place your snippets for typescript here. Each snippet is defined under a snippet name and has a prefix, body and
  // description. The prefix is what is used to trigger the snippet and the body will be expanded and inserted. Possible variables are:
  // $1, $2 for tab stops, $0 for the final cursor position, and ${1:label}, ${2:another} for placeholders. Placeholders with the
  // same ids are connected.
  // Example:
  // "Print to console": {
  // 	"prefix": "log",
  // 	"body": [
  // 		"console.log('$1');",
  // 		"$2"
  // 	],
  // 	"description": "Log output to console"
  // }
  "effect Context.Tag": {
    "prefix": "efctag",
    "body": ["class $1 extends Context.Tag(\"$1\")<$1, $2>() {}"],
    "description": "context tag",
  },
  "effect Context.Reference": {
    "prefix": "efref",
    "body": ["class $1 extends Context.Reference<$1>()(\"$1\", { defaultValue: () => $2 }) {}"],
    "description": "context reference",
  },
  "Effect.gen(function* () {...})": {
    "prefix": "efgen",
    "body": ["Effect.gen(function* () {", "  $1", "})"],
    "description": "effect gen"
  },
  "Effect.fn(function* () {...})": {
    "prefix": "effn",
    "body": ["Effect.fn(function* () {", "  $1", "})"],
    "description": "effect fn"
  },
