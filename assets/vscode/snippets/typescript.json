  "Effect Schema.Class": {
    "prefix": "efsc",
    "body": [
      "class $1 extends Schema.Class<$1>(\"$1\")({",
      "    $2: $3,",
      "}) {}"
    ],
    "description": "schema tagged request"
  },
  "effect Effect.Service": {
    "prefix": "efs",
    "body": [
      "export class $1 extends Effect.Service<$1>()(\"$1\", {",
      "    accessors: true,",
      "    effect: $2,",
      "}) {}"
    ],
    "description": "schema tagged request"
  },
