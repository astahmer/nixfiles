  "effect Schema.TaggedError": {
    "prefix": "efserr",
    "body": [
      "class $1 extends Schema.TaggedError<$1>()(",
      "  \"$1\",",
      "  {",
      "  ${2:cause: Schema.Any,}",
      "  },",
      ") {}"
    ],
    "description": "schema error"
  },
