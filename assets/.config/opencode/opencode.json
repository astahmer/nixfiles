{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "readbro": {
      "enabled": true,
      "type": "local",
      "command": [
        "readbro"
      ]
    },
    "github": {
      "enabled": true,
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer {env:GITHUB_TOKEN}"
      }
    }
  }
}
