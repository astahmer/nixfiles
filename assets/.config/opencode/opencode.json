{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "cachebro": {
      "enabled": false,
      "type": "local",
      "command": [
        "cachebro",
        "serve"
      ]
    },
    "composto": {
      "enabled": true,
      "type": "local",
      "command": [
        "composto-mcp"
      ]
    },
    "github": {
      "enabled": true,
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer {env:GITHUB_TOKEN}"
      }
    }
  }
}
