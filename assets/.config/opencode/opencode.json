{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "composto-cachebro": {
      "enabled": true,
      "type": "local",
      "command": [
        "composto-cachebro"
      ]
    },
    "composto": {
      "enabled": true,
      "type": "local",
      "command": [
        "composto-mcp"
      ],
      "environment": {
        "COMPOSTO_BLASTRADIUS": "1"
      }
    },
    "github": {
      "enabled": true,
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer {env:GITHUB_TOKEN}"
      }
    }
  }
}
