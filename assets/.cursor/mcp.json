{
    "mcpServers": {
        "composto": {
            "command": "composto-mcp"
        },
        "cachebro": {
            "command": "npx",
            "args": [
                "cachebro",
                "serve"
            ]
        },
        "github": {
            "url": "https://api.githubcopilot.com/mcp/",
            "headers": {
                "Authorization": "Bearer {env:GITHUB_TOKEN}"
            }
        }
    }
}
